# ============================================================================
# Top-level aggregator that transitions all 2025.1-only targets in one go.
# Tagged `manual` so `bazel build //...` (e.g. on CI without a Vivado install)
# skips it — its underlying targets are vivado-action heavy and would fail in
# an env without vivado 2025.1. Build explicitly when you do have it:
#   bazel build //tests:all_bram_2025_1
# ============================================================================

with_vivado_version(
    name = "all_bram_2025_1",
    tags = ["manual"],
    targets = [
        ":bram_read_only_interface_ip",
        ":bram_write_only_interface_ip",
        ":bram_read_write_splitter_ip",
        ":test_reader_ip",
        ":test_writer_ip",
        ":interface_example_project",
    ],
    vivado_version = "2025.1",
)
