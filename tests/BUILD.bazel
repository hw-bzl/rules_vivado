)

# ============================================================================
# BRAM Read/Write Splitter - separate read and write interfaces for BRAM.
# Every rule below is `target_compatible_with` `//vivado/settings:version_2025.1`
# (via the _REQUIRES_VIVADO_2025_1 select) and tagged manual, so they don't get
# picked up by `//...` on their own. Build them through the `:all_bram_2025_1`
# wrapper at the bottom of this file, which uses `with_vivado_version` to
# transition the version flag + exec platform for the whole group in one shot.
# ============================================================================

_REQUIRES_VIVADO_2025_1 = ["//vivado/constraints/version:2025.1"]

# Read-only BRAM interface definition (IP-XACT)
vivado_interface_definition(
    name = "bram_read_only_interface",
    src = "bram_read_only_if.sv",
    description = "Read-only BRAM interface with address, enable, data, and valid",
    interface_name = "bram_read_only_if",
    library = "interfaces",
    tags = ["manual"],
    target_compatible_with = _REQUIRES_VIVADO_2025_1,
    vendor = "test_vendor",
    version = "1.0",
)

# Write-only BRAM interface definition (IP-XACT)
vivado_interface_definition(
    name = "bram_write_only_interface",
    src = "bram_write_only_if.sv",
    description = "Write-only BRAM interface with address, enable, byte-write-enable, and data",
    interface_name = "bram_write_only_if",
    library = "interfaces",
    tags = ["manual"],
    target_compatible_with = _REQUIRES_VIVADO_2025_1,
    vendor = "test_vendor",
    version = "1.0",
)

# Interface SV sources with IP-XACT data
verilog_library(
    name = "bram_read_only_if",
    srcs = ["bram_read_only_if.sv"],
    data = [":bram_read_only_interface"],
)

verilog_library(
    name = "bram_write_only_if",
    srcs = ["bram_write_only_if.sv"],
    data = [":bram_write_only_interface"],
)

# Splitter module
verilog_library(
    name = "bram_read_write_splitter",
    srcs = ["bram_read_write_splitter.sv"],
    deps = [
        ":bram_read_only_if",
        ":bram_write_only_if",
    ],
)

# Interface IP packages (make custom interfaces available in Vivado IP catalog)
vivado_create_interface_ip(
    name = "bram_read_only_interface_ip",
    interface = ":bram_read_only_interface",
    module = ":bram_read_only_if",
    part_number = "xczu28dr-ffvg1517-2-e",
    tags = ["manual"],
    target_compatible_with = _REQUIRES_VIVADO_2025_1,
)

vivado_create_interface_ip(
    name = "bram_write_only_interface_ip",
    interface = ":bram_write_only_interface",
    module = ":bram_write_only_if",
    part_number = "xczu28dr-ffvg1517-2-e",
    tags = ["manual"],
    target_compatible_with = _REQUIRES_VIVADO_2025_1,
)

# IP wrapper with flat ports and X_INTERFACE directives
verilog_library(
    name = "bram_read_write_splitter_wrapper",
    srcs = ["bram_read_write_splitter_wrapper.sv"],
    deps = [":bram_read_write_splitter"],
)

# Packaged IP block
vivado_create_ip(
    name = "bram_read_write_splitter_ip",
    ip_blocks = [
        ":bram_read_only_interface_ip",
        ":bram_write_only_interface_ip",
    ],
    ip_library = "ip",
    ip_vendor = "test_vendor",
    ip_version = "1.0",
    module = ":bram_read_write_splitter_wrapper",
    module_top = "bram_read_write_splitter_wrapper",
    part_number = "xczu28dr-ffvg1517-2-e",
    tags = ["manual"],
    target_compatible_with = _REQUIRES_VIVADO_2025_1,
)

