# Create the interface IP directory structure
file mkdir {{IP_OUTPUT_DIR}}

# Copy interface definition files to IP directory
# Vivado auto-discovers bus definitions and abstraction definitions
# from IP repository paths - no component.xml wrapper is needed.
file copy -force {{BUS_DEFINITION_FILE}} {{IP_OUTPUT_DIR}}/
file copy -force {{ABSTRACTION_DEFINITION_FILE}} {{IP_OUTPUT_DIR}}/

puts "Interface IP created at {{IP_OUTPUT_DIR}}"
